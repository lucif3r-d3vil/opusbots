# Copy this file to .env and fill in real values. Do NOT commit .env.
#
# ADMIN_USER / ADMIN_PASS / FLASK_SECRET_KEY control the config-web login
# page only -- bot tokens, qBittorrent creds, and media paths are set from
# that page and live in config/config.json instead.

ADMIN_USER=admin
ADMIN_PASS=change-me-to-something-strong

# Generate your own, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Optional. The folder on this host that holds Movies/, Music/, and
# Downloads/ -- gets mounted into every bot container at /tank.
# Defaults to /tank if you don't set this.
MEDIA_ROOT=/tank
