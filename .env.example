# Copy this file to .env and fill in real values. Do NOT commit .env.
#
# These only control the config-web login page, NOT the bots themselves —
# bot tokens, qBittorrent creds, and media paths are set from that page
# and live in config/config.json instead.

ADMIN_USER=admin
ADMIN_PASS=change-me-to-something-strong

# Generate your own, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-64-char-hex-string
